#!/usr/bin/env bash
#
# commit-msg: commit message discipline.
#
# Blocks:
#   1. Co-author trailers. The author is the author; tools are tools.
#   2. AI-attribution boilerplate ("Generated with ...", tool footers,
#      the robot emoji, "AI-assisted", and the wider set).
#   3. Bypass markers in the message text ("no-verify", "skip hooks").
#      If --no-verify was used this hook does not run, but the marker
#      sitting in the message is a smell and is blocked.
#
# Implements §8 of the engineering baseline.
#
# Hyphens are NOT checked here: the no-hyphen rule targets user-facing
# strings, and a commit message is git metadata, not user-facing copy.

set -eu

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")

RED=$(tput setaf 1 2>/dev/null || true)
BOLD=$(tput bold 2>/dev/null || true)
RESET=$(tput sgr0 2>/dev/null || true)

FAIL=0

# 1. Co-author trailers.
if echo "$MSG" | grep -qiE '^[[:space:]]*Co-Authored-By:'; then
    echo
    echo "${RED}${BOLD}COMMIT-MSG GATE: co-author trailer forbidden${RESET}"
    echo "$MSG" | grep -iE '^[[:space:]]*Co-Authored-By:' | sed 's/^/  /'
    FAIL=1
fi

# 2. AI-attribution boilerplate.
AI_PATTERNS=(
    'Generated with .*Claude'
    'Generated with .*Copilot'
    'Generated with .*Cursor'
    'Generated with .*GPT'
    'Co-Authored-By: Claude'
    'noreply@anthropic\.com'
    'claude\.com/claude-code'
    'Authored by .*(Claude|Copilot|GPT|AI)'
    'made with .*(Claude|Copilot|GPT|AI)'
    'with help from .*(Claude|Copilot|GPT)'
    'AI-?assisted'
    'AI-?generated'
    'Generated by AI'
    $'\xf0\x9f\xa4\x96'
)
AI_HITS=()
for p in "${AI_PATTERNS[@]}"; do
    if echo "$MSG" | grep -qiE "$p"; then AI_HITS+=("$p"); fi
done
if [[ ${#AI_HITS[@]} -gt 0 ]]; then
    echo
    echo "${RED}${BOLD}COMMIT-MSG GATE: AI-attribution boilerplate forbidden${RESET}"
    for p in "${AI_HITS[@]}"; do echo "  matched: $p"; done
    FAIL=1
fi

# 3. Bypass markers in the message.
if echo "$MSG" | grep -qiE '(no[- ]verify|skip[- ]hooks|bypass[- ]gate)'; then
    echo
    echo "${RED}${BOLD}COMMIT-MSG GATE: bypass marker in message${RESET}"
    echo "  Strip the bypass marker from the commit text."
    FAIL=1
fi

[[ $FAIL -eq 1 ]] && { echo; exit 1; }
exit 0

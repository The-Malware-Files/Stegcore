#!/usr/bin/env bash
#
# pre-push: branch protection + secret sweep + large-file guard
#           + optional scoped Rust gates.
#
# Refuses force-push to main/master. Refuses direct push to main/master
# (branch + PR workflow). Refuses any push to a remote named 'upstream'
# (by convention the source repo you never push to directly). Sweeps the
# commits being pushed for secret-shaped content. Blocks files over 5 MB
# without explicit confirmation. If the repo is a Rust workspace, runs
# fmt + clippy scoped to the changed files.
#
# Implements Section 8 and Section 13 of the engineering baseline.
#
# Bypass: git push --no-verify   (last resort).

set -eu

RED=$(tput setaf 1 2>/dev/null || true)
YELLOW=$(tput setaf 3 2>/dev/null || true)
GREEN=$(tput setaf 2 2>/dev/null || true)
BOLD=$(tput bold 2>/dev/null || true)
RESET=$(tput sgr0 2>/dev/null || true)

remote="$1"

# Git sends an all-zeros sha for a brand-new (or deleted) ref. The zeros
# string must match the hash length in use, so derive it from a real hash
# rather than hard-coding 40 zeros (SHA-256 repos use 64).
zero=$(git hash-object --stdin </dev/null | tr '0-9a-f' '0')

# ── Never push to 'upstream' ────────────────────────────────────────────────
if [ "$remote" = "upstream" ]; then
    echo "${RED}${BOLD}REFUSED${RESET}: push to the 'upstream' remote."
    echo "By convention 'upstream' is the source repo. Push to 'origin'"
    echo "and let changes reach upstream through a pull request."
    exit 1
fi

# ── Read the ref updates from stdin ─────────────────────────────────────────
# Each line: <local_ref> <local_sha> <remote_ref> <remote_sha>
protected_violation=0
force_to_protected=0
RELEASE_TAGS_MISSING_CODENAME=()
PUSH_LOCAL=()
PUSH_REMOTE=()
while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "${remote_ref:-}" ] && continue
    # A deleted ref (local_sha all zeros) has nothing to scan.
    [ "$local_sha" = "$zero" ] && continue
    branch="${remote_ref#refs/heads/}"
    if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
        protected_violation=1
        if [ "$remote_sha" != "$zero" ] \
           && ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
            force_to_protected=1
        fi
    fi
    # Release-tag codename gate (CLAUDE.md Section 22).
    # Annotated `v*` tags must carry a `Codename:` line. Override:
    # SKIP_TAG_CODENAME=1 git push (recorded reason required).
    if [[ "$remote_ref" == refs/tags/v* ]] && [ "${SKIP_TAG_CODENAME:-0}" != "1" ]; then
        tag_name="${remote_ref#refs/tags/}"
        # Only inspect annotated tags (lightweight tags point at commits).
        obj_type=$(git cat-file -t "$local_sha" 2>/dev/null || echo "")
        if [ "$obj_type" = "tag" ]; then
            tag_msg=$(git cat-file -p "$local_sha" 2>/dev/null | awk 'BEGIN{p=0} /^$/{p=1; next} p{print}')
            if ! echo "$tag_msg" | grep -qiE '^Codename:[[:space:]]*[^[:space:]]'; then
                RELEASE_TAGS_MISSING_CODENAME+=("$tag_name")
            fi
        fi
    fi
    PUSH_LOCAL+=("$local_sha")
    PUSH_REMOTE+=("$remote_sha")
done

if [ "$force_to_protected" -eq 1 ]; then
    echo "${RED}${BOLD}REFUSED${RESET}: force-push to main/master."
    echo "Open a revert PR instead."
    exit 1
fi
if [ "$protected_violation" -eq 1 ]; then
    echo "${RED}${BOLD}REFUSED${RESET}: direct push to main/master."
    echo "Push a branch and open a pull request."
    exit 1
fi

if [ "${#RELEASE_TAGS_MISSING_CODENAME[@]}" -gt 0 ]; then
    echo "${RED}${BOLD}REFUSED${RESET}: release tag missing a Codename: line."
    echo
    echo "Per CLAUDE.md Section 22, annotated v* tags carry a human codename"
    echo "chosen by the user (typically a TV series / anime / film they"
    echo "are currently watching). The codename belongs in the tag"
    echo "message as a 'Codename: <name>' line near the top."
    echo
    echo "Tags failing the check:"
    for t in "${RELEASE_TAGS_MISSING_CODENAME[@]}"; do
        echo "  - ${BOLD}${t}${RESET}"
    done
    echo
    echo "Fix:"
    echo "  git tag -d <tag>"
    echo "  git tag -a <tag> -m \"<tag> — <Codename>\" -m \"Codename: <Codename>\""
    echo "  git push origin <tag>"
    echo
    echo "Bypass (last resort, with recorded reason):"
    echo "  SKIP_TAG_CODENAME=1 git push --tags"
    exit 1
fi

[ "${#PUSH_LOCAL[@]}" -eq 0 ] && exit 0

# ── Resolve the exact commits being pushed ──────────────────────────────────
# Updated branch: the commits between the old and new remote tip.
# New branch:     the commits on this branch not present on any remote.
COMMITS=()
i=0
while [ "$i" -lt "${#PUSH_LOCAL[@]}" ]; do
    ls="${PUSH_LOCAL[$i]}"
    rs="${PUSH_REMOTE[$i]}"
    if [ "$rs" = "$zero" ]; then
        revs=$(git rev-list "$ls" --not --remotes 2>/dev/null || true)
    else
        revs=$(git rev-list "${rs}..${ls}" 2>/dev/null || true)
    fi
    while IFS= read -r c; do
        [ -n "$c" ] && COMMITS+=("$c")
    done <<<"$revs"
    i=$(( i + 1 ))
done

if [ "${#COMMITS[@]}" -eq 0 ]; then
    echo "${GREEN}${BOLD}pre-push: nothing new to scan; gates passed${RESET}"
    exit 0
fi

# ── Secret sweep across the pushed commits ──────────────────────────────────
SECRET_REGEX=(
    '-----BEGIN [A-Z ]*PRIVATE KEY-----'
    'AKIA[0-9A-Z]{16}'
    'ASIA[0-9A-Z]{16}'
    'gh[pousr]_[A-Za-z0-9]{36,}'
    'github_pat_[A-Za-z0-9_]{50,}'
    'glpat-[A-Za-z0-9_-]{20,}'
    'xox[baprs]-[A-Za-z0-9-]{10,}'
    'AIza[0-9A-Za-z_-]{35}'
    'sk-[A-Za-z0-9]{20,}'
    'sk_live_[0-9A-Za-z]{20,}'
    'whsec_[0-9A-Za-z]{20,}'
)
JOIN() { local IFS='|'; printf '%s' "$*"; }
SECRET_JOINED=$(JOIN "${SECRET_REGEX[@]}")

ALLOW_PATTERNS=()
if [ -f .baseline-hook-allow ]; then
    while IFS= read -r l; do
        [ -z "$l" ] && continue
        case "$l" in \#*) continue ;; esac
        ALLOW_PATTERNS+=("$l")
    done < .baseline-hook-allow
fi
allowlisted() {
    for p in "${ALLOW_PATTERNS[@]:-}"; do
        [ -z "$p" ] && continue
        echo "$1" | grep -qE -e "$p" && return 0
    done
    return 1
}

SECRET_HITS=()
for c in "${COMMITS[@]}"; do
    added=$(git show --unified=0 --no-color --diff-filter=AM --format= "$c" 2>/dev/null \
            | grep -E '^\+' | grep -vE '^\+\+\+' || true)
    [ -z "$added" ] && continue
    while IFS= read -r line; do
        content="${line:1}"
        if echo "$content" | grep -qiE -e "$SECRET_JOINED" && ! allowlisted "$content"; then
            SECRET_HITS+=("    ${c:0:9}  ${content:0:110}")
        fi
    done <<<"$added"
done

if [ "${#SECRET_HITS[@]}" -gt 0 ]; then
    echo "${RED}${BOLD}SECRET GATE: push blocked${RESET}"
    echo "Commits in this push add lines that look like credentials:"
    printf '%s\n' "${SECRET_HITS[@]}"
    echo "Scrub them, rewrite the offending commits, and rotate the secret."
    exit 1
fi

# ── Large-file guard ────────────────────────────────────────────────────────
LARGE=()
for c in "${COMMITS[@]}"; do
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        [ -f "$f" ] || continue
        sz=$(wc -c <"$f" 2>/dev/null || echo 0)
        [ "$sz" -gt 5242880 ] && LARGE+=("$f ($((sz/1024)) KB)")
    done < <(git diff-tree --no-commit-id --name-only -r "$c" 2>/dev/null || true)
done
if [ "${#LARGE[@]}" -gt 0 ] && [ -z "${BASELINE_LARGE_FILE_OK:-}" ]; then
    echo "${RED}${BOLD}LARGE-FILE GATE: push blocked${RESET}"
    printf '  %s\n' "${LARGE[@]}" | sort -u
    echo "Confirm with: ${BOLD}BASELINE_LARGE_FILE_OK=1 git push${RESET}"
    echo "Better: git-lfs, an asset store, or keep the binary out of git."
    exit 1
fi

# ── Version-consistency gate ────────────────────────────────────────────────
# If the project declares its version in multiple files (workspace crates +
# Tauri conf + frontend package.json), all of them must agree. Skips
# gracefully if the project has no version files at all.
#
# Project root config (.baseline-hook-config) can extend the discovery list:
#   VERSION_FILES=(Cargo.toml src-tauri/Cargo.toml ...)
# Default discovery: every Cargo.toml with a `[package]` block + every
# package.json + tauri.conf.json + tauri.conf.json5.
repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# Source config if present (already sourced by pre-commit; idempotent).
if [[ -f .baseline-hook-config ]]; then
    # shellcheck disable=SC1091
    . ./.baseline-hook-config
fi

if [[ -z "${VERSION_FILES:-}" ]]; then
    # Auto-discover. Find Cargo.toml with a [package] block; package.json
    # with a "version" field; tauri.conf.json{,5}. Skip target/, node_modules/,
    # vendored deps.
    AUTO_VERSIONS=()
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        case "$f" in
            */target/*|*/node_modules/*|*/vendor/*|*/private/*|*/fuzz/*) continue ;;
        esac
        if grep -qE '^\[package\]' "$f" 2>/dev/null; then
            # Skip unpublished sub-workspaces. Two conventions:
            #   (a) version = "0.0.0" (the canonical "never published" marker)
            #   (b) publish = false in the [package] block
            if grep -qE '^version[[:space:]]*=[[:space:]]*"0\.0\.0"' "$f" 2>/dev/null \
            || grep -qE '^publish[[:space:]]*=[[:space:]]*false' "$f" 2>/dev/null ; then
                continue
            fi
            AUTO_VERSIONS+=("$f")
        fi
    done < <(find . -name Cargo.toml -not -path '*/target/*' -not -path '*/node_modules/*' -not -path '*/private/*' 2>/dev/null)
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        case "$f" in
            */target/*|*/node_modules/*|*/vendor/*|*/private/*) continue ;;
        esac
        if grep -qE '"version":' "$f" 2>/dev/null; then
            AUTO_VERSIONS+=("$f")
        fi
    done < <(find . \( -name package.json -o -name 'tauri.conf.json' -o -name 'tauri.conf.json5' \) -not -path '*/node_modules/*' 2>/dev/null)
    VERSION_FILES=("${AUTO_VERSIONS[@]}")
fi

if [[ "${#VERSION_FILES[@]}" -gt 0 ]]; then
    declare -A SEEN_VERSIONS
    DRIFT_LIST=()
    for f in "${VERSION_FILES[@]}"; do
        [[ -f "$f" ]] || continue
        case "$f" in
            *Cargo.toml)
                v=$(awk '/^\[package\]/{flag=1; next} /^\[/{flag=0} flag && /^version[[:space:]]*=/{gsub(/[" ]/,"",$3); print $3; exit}' "$f" 2>/dev/null)
                # Fallback: first version line if package block parsing missed.
                if [[ -z "$v" ]]; then
                    v=$(grep -E '^version[[:space:]]*=' "$f" 2>/dev/null | head -1 | sed -E 's/.*"([^"]+)".*/\1/')
                fi
                ;;
            *package.json|*tauri.conf.json|*tauri.conf.json5)
                if command -v jq >/dev/null 2>&1; then
                    v=$(jq -r '.version // empty' "$f" 2>/dev/null)
                else
                    v=$(grep -E '"version":' "$f" 2>/dev/null | head -1 | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')
                fi
                ;;
            *) continue ;;
        esac
        if [[ -n "$v" ]]; then
            SEEN_VERSIONS["$f"]="$v"
            DRIFT_LIST+=("$f=$v")
        fi
    done

    # Detect drift.
    UNIQUE_VERSIONS=$(printf '%s\n' "${SEEN_VERSIONS[@]}" | sort -u | wc -l)
    if [[ "$UNIQUE_VERSIONS" -gt 1 ]]; then
        echo "${RED}${BOLD}VERSION-DRIFT GATE: push blocked${RESET}"
        echo
        echo "Version declarations across the repo do not agree:"
        echo
        for entry in "${DRIFT_LIST[@]}"; do
            printf '  %s\n' "$entry"
        done
        echo
        echo "${YELLOW}Fix:${RESET} bump every declaration to the same value before pushing."
        echo "${YELLOW}Skip (override):${RESET} BASELINE_VERSION_DRIFT_OK=1 git push"
        [[ -z "${BASELINE_VERSION_DRIFT_OK:-}" ]] && exit 1
    fi
fi

# ── Optional Rust gates, scoped to changed files ────────────────────────────
if [ ! -f "$repo_root/Cargo.toml" ]; then
    echo "${GREEN}${BOLD}pre-push: branch + secret + size + version gates passed${RESET}"
    exit 0
fi

CHANGED_RS=()
for c in "${COMMITS[@]}"; do
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        case "$f" in *.rs) [ -f "$f" ] && CHANGED_RS+=("$f") ;; esac
    done < <(git diff-tree --no-commit-id --name-only -r "$c" 2>/dev/null || true)
done
if [ "${#CHANGED_RS[@]}" -eq 0 ]; then
    echo "${GREEN}${BOLD}pre-push: gates passed (no Rust files changed)${RESET}"
    exit 0
fi
mapfile -t CHANGED_RS < <(printf '%s\n' "${CHANGED_RS[@]}" | sort -u)

echo "${BOLD}==> rustfmt --check (${#CHANGED_RS[@]} file(s))${RESET}"
if ! rustfmt --check --edition 2021 "${CHANGED_RS[@]}"; then
    echo "${RED}${BOLD}REFUSED${RESET}: rustfmt --check failed."
    exit 1
fi

# Clippy scope: defaults to whole workspace via --all-targets. A
# project with system-dep-heavy crates (Tauri's libsoup, GTK, etc.)
# can scope clippy to the changed-frequently subset by setting
# CLIPPY_PACKAGES in .baseline-hook-config:
#   CLIPPY_PACKAGES='-p stegcore-engine -p stegcore-core -p stegcore-cli'
CLIPPY_PACKAGES="${CLIPPY_PACKAGES:-}"
echo "${BOLD}==> cargo clippy ${CLIPPY_PACKAGES} --all-targets -- -D warnings${RESET}"
# shellcheck disable=SC2086
if ! cargo clippy $CLIPPY_PACKAGES --all-targets -- -D warnings; then
    echo "${RED}${BOLD}REFUSED${RESET}: cargo clippy failed."
    exit 1
fi

echo "${GREEN}${BOLD}pre-push: all gates passed${RESET}"
exit 0
